# ═════════════════════════════════════════════════════
#   System 777 — Web (.env.example)
#   Copia a .env.local y rellena los valores reales.
#   También configurar en Vercel Dashboard → Settings → Env Vars
# ═════════════════════════════════════════════════════

# ── Discord OAuth ──
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── NextAuth (genera secret: openssl rand -base64 32) ──
NEXTAUTH_URL=https://tu-dominio.vercel.app
NEXTAUTH_SECRET=

# ── Bot API (Railway) — server-side, no expuesta al cliente ──
BOT_API_URL=https://tu-bot.railway.app

# ── Públicas ──
NEXT_PUBLIC_WEB_URL=https://tu-dominio.vercel.app
NEXT_PUBLIC_CLIENT_ID=
NEXT_PUBLIC_SUPPORT_URL=
