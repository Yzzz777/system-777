# ══════════════════════════════════════════
#   SYSTEM 777 — Configuración de entorno
#   Copia este archivo como .env y rellénalo
# ══════════════════════════════════════════

# ── TOKEN DEL BOT (Discord Developer Portal) ──
BOT_TOKEN=TU_TOKEN_AQUI

# ── TU USER ID DE DISCORD (dueño del bot) ──
OWNER_ID=TU_ID_AQUI

# ── CLIENT ID DEL BOT (Application ID) ──
CLIENT_ID=CLIENT_ID_AQUI

# ── ID DE SERVIDOR DE DESARROLLO (para comandos de dueño) ──
DEV_GUILD_ID=ID_SERVIDOR_DEV_AQUI

# ── DASHBOARD WEB ──
DASHBOARD_PORT=3000
DASHBOARD_SECRET=CAMBIA_ESTA_CLAVE_SECRETA_LARGA

# ── DISCORD OAUTH (para login en el dashboard) ──
# Obtén esto en Discord Developer Portal > tu aplicación > OAuth2 > Client Secret
CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
# Solo necesario si no usas ngrok con dominio fijo
# DISCORD_CALLBACK_URL=https://tu-dominio.ngrok-free.app/auth/discord/callback

# ── NGROK (acceso público al dashboard desde cualquier parte) ──
# 1. Crea cuenta gratis en ngrok.com
# 2. Copia el authtoken de tu dashboard de ngrok
# 3. En ngrok.com/domains reclama tu dominio gratis (ej: system-777-abc.ngrok-free.app)
NGROK_AUTHTOKEN=TU_AUTHTOKEN_DE_NGROK
# Dominio estático (sin esto la URL cambia cada reinicio)
NGROK_DOMAIN=tu-dominio.ngrok-free.app

# ── ANTI-RAID: joins permitidos antes de activar protección ──
RAID_JOIN_THRESHOLD=10
RAID_JOIN_WINDOW_MS=10000

# ── CUENTA MÍNIMA EN DÍAS para no ser detectado como sospechoso ──
MIN_ACCOUNT_AGE_DAYS=7

# ── ANTHROPIC API KEY (para chat con IA en DMs) ──
ANTHROPIC_API_KEY=
